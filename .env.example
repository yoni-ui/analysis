# Optional: Groq for structured tactical JSON (used by app/api/tactical Route Handler).
# Server-only — not exposed to the browser when using the API route.
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Gemini enriches the briefing (markdown appended server-side).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# If you skip GROQ_API_KEY, the API route uses deterministic mock analysis (still useful for demos).

# Do NOT put provider keys in NEXT_PUBLIC_* unless you accept they are visible to anyone
# who opens the site (not recommended for public deployments).
